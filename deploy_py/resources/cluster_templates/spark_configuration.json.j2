 {
    "spark-env" : {
      "spark_log_dir": "{{ base_log_dir }}/spark",
      "spark_daemon_memory": "{{spark_daemon_memory}}"
    },
    "spark-defaults": {
      "spark_daemon_memory": "2g",
      "spark.dynamicAllocation.executorIdleTimeout": "5s",
      "spark.dynamicAllocation.cachedExecutorIdleTimeout": "30min",
      "spark.dynamicAllocation.initialExecutors": "2",
      "spark.dynamicAllocation.maxExecutors": "500",
      "spark.dynamicAllocation.minExecutors": "2",
      "spark.dynamicAllocation.schedulerBacklogTimeout": "1s",
      "spark.dynamicAllocation.shuffleTracking.enabled": "false",
      "spark.dynamicAllocation.shuffleTracking.timeout": "30min",
      "spark.dynamicAllocation.sustainedSchedulerBacklogTimeout": "1s",
      "spark.sql.adaptive.coalescePartitions.enabled": "true",
      "spark.sql.adaptive.coalescePartitions.initialPartitionNum": "400",
      "spark.sql.adaptive.coalescePartitions.minPartitionNum": "20",
      "spark.sql.adaptive.enabled": "true",
      "spark.sql.adaptive.localShuffleReader.enabled": "false",
      "spark.sql.adaptive.skewJoin.enabled": "true",
      "spark.sql.adaptive.skewJoin.skewedPartitionFactor": "10",
      "spark.sql.adaptive.skewJoin.skewedPartitionThresholdInBytes": "256MB",
      "spark.sql.debug.maxToStringFields": "300",
      "spark.sql.hive.convertMetastoreParquet": "false",
      "spark.sql.legacy.timeParserPolicy": "LEGACY",
      "spark.sql.shuffle.partitions": "500",
      "spark.sql.storeAssignmentPolicy": "LEGACY",
      "spark.driver.maxResultSize": "4G",
      "spark.driver.memory": "4G",
      "spark.driver.memoryOverhead": "4g",
      "spark.dynamicAllocation.minExecutors": "0",
      "spark.dynamicAllocation.executorAllocationRatio": "0.5",
      "spark.executor.memoryOverhead": "1",
      "spark.default.parallelism": "500",
      "spark.network.timeout": "600s",
      "spark.executor.heartbeatInterval": "300s",
      "spark.executor.memory": "4g",
      "spark.executor.memoryOverhead": "1g",
      "spark.hadoop.mapred.input.dir.recursive": "true",
      "spark.sql.optimizer.insertRepartitionBeforeWrite.enabled": "true",
      "spark.sql.adaptive.advisoryPartitionSizeInBytes": "512M"
    }
}